# ============================================================
# Destaco.es — Variables de entorno
# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env
# ============================================================

# ---- Base de datos (PostgreSQL) ----
# Con Docker Compose (docker compose up -d) usa este valor tal cual:
DATABASE_URL="postgresql://destaco:destaco@localhost:5432/destaco?schema=public"

# ---- Redis (cache + colas de scraping) ----
REDIS_URL="redis://localhost:6379"

# ---- Autenticacion (Auth.js v5 / NextAuth) ----
# Genera un secreto con:  openssl rand -base64 32
AUTH_SECRET=""
# URL publica de la app (en local dejalo asi)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Login con Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Contrasena del usuario admin que crea el seed (admin@destaco.es).
# Cambiala antes de cualquier despliegue real.
ADMIN_PASSWORD="Destaco2026!"

# ---- OpenAI (enriquecimiento de empresas con IA) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ---- Fuentes de datos (ingesta legal de empresas) ----
# Google Places API (de pago, legal) — https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=""
# Overpass API de OpenStreetMap (gratis, sin key)
OVERPASS_API_URL="https://overpass-api.de/api/interpreter"

# ---- Stripe (monetizacion: planes y perfiles destacados) ----
# https://dashboard.stripe.com/apikeys  (usa claves de test en desarrollo)
STRIPE_SECRET_KEY=""
# Secreto del endpoint del webhook (Developers > Webhooks).
# Endpoint a registrar:  https://destaco.es/api/stripe/webhook
# Eventos: checkout.session.completed, customer.subscription.created/updated/deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# ID del precio del plan Destacado (49,99 €/año recurrente). Products > Add product.
STRIPE_PRICE_ID=""
# ID del tipo de impuesto IVA 21% (Product catalog > Tax rates). Si se deja
# vacio, el checkout no añade IVA (util para pruebas rapidas).
STRIPE_TAX_RATE_ID=""

# ---- Cron / jobs protegidos ----
# Secreto que deben enviar los cron jobs para disparar la ingesta.
CRON_SECRET=""

# ---- Email transaccional (Resend — verificacion de reclamaciones, avisos) ----
# https://resend.com/api-keys  (el dominio debe estar verificado en Resend)
RESEND_API_KEY=""
RESEND_FROM="Destaco.es <hola@destaco.es>"

# ---- Email (SMTP — newsletters y notificaciones) ----
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Destaco.es <hola@destaco.es>"

# ---- Metricas (privacidad RGPD) ----
# Sal para hashear las IP (SHA-256). Genera con: openssl rand -hex 16
# Las IP NUNCA se guardan en claro, solo su hash.
METRICS_SALT=""

# ---- Google Search Console API (indexacion — opcional) ----
# Cuenta de servicio con acceso a la propiedad de Search Console.
# Enviar el sitemap NO garantiza la indexacion: Google decide.
# Propiedad: "sc-domain:destaco.es" o "https://destaco.es/"
SEARCH_CONSOLE_SITE_URL=""
GOOGLE_SC_CLIENT_EMAIL=""
# Clave privada de la cuenta de servicio (con \n escapados, entre comillas).
GOOGLE_SC_PRIVATE_KEY=""

# ---- Analitica (opcional) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Destaco.es"
